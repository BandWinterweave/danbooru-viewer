{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "chrome"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsconfig-node"
  },
  "include": ["vite.config.ts", "playwright.config.ts", "tailwind.config.ts", "src/manifest.json"]
}
