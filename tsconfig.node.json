{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsconfig-node"
  },
  "include": ["vite.config.ts", "src/manifest.json"]
}
