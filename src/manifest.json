{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.1.0",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "downloads", "unlimitedStorage", "scripting", "declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "https://*.donmai.us/*",
    "https://gelbooru.com/*",
    "https://*.gelbooru.com/*",
    "https://*.safebooru.org/*",
    "https://*.yande.re/*",
    "https://*.rule34.xxx/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "gelbooru_media_headers",
        "enabled": true,
        "path": "rules/gelbooru-media.json"
      }
    ]
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["https://danbooru.donmai.us/posts*", "https://danbooru.donmai.us/posts/*"],
    "js": ["src/content/index.ts"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Danbooru Viewer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "danbooru-viewer@example.com",
      "strict_min_version": "109.0"
    }
  }
}
