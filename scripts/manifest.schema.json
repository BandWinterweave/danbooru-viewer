{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "manifest_version",
    "name",
    "version",
    "permissions",
    "host_permissions",
    "background",
    "action",
    "chrome_url_overrides",
    "content_security_policy"
  ],
  "properties": {
    "manifest_version": { "const": 3 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){0,3}$" },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["storage", "downloads", "unlimitedStorage", "scripting", "declarativeNetRequestWithHostAccess"]
      }
    },
    "host_permissions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^https?://" }
    },
    "background": {
      "type": "object",
      "oneOf": [
        {
          "required": ["service_worker"],
          "properties": {
            "service_worker": { "type": "string", "minLength": 1 },
            "type": { "const": "module" }
          },
          "additionalProperties": false
        },
        {
          "required": ["scripts"],
          "properties": {
            "scripts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          },
          "additionalProperties": false
        }
      ]
    },
    "action": {
      "type": "object",
      "required": ["default_popup"],
      "properties": { "default_popup": { "type": "string", "minLength": 1 } }
    },
    "chrome_url_overrides": {
      "type": "object",
      "required": ["newtab"],
      "properties": { "newtab": { "type": "string", "minLength": 1 } }
    },
    "content_security_policy": {
      "type": "object",
      "required": ["extension_pages"],
      "properties": {
        "extension_pages": {
          "const": "script-src 'self'; object-src 'self'"
        }
      },
      "additionalProperties": false
    }
  }
}
